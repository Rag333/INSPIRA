<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet" />
    <style>
      /* Smooth image loading */
      img { transition: opacity 0.3s ease-in-out; }
      img[loading] { opacity: 0; }
      img.loaded { opacity: 1; }
    </style>
  </head>
  <body class="bg-gray-50 min-h-screen font-sans">
    
    <!-- Glassmorphism Navbar -->
    <nav id="navbar" class="sticky top-0 z-50 flex items-center justify-between px-6 py-4 backdrop-blur-md bg-white/80 shadow-sm border-b border-gray-200/50 transition-all duration-300">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-red-600 flex items-center justify-center text-white font-bold italic">I</div>
            <div class="text-xl font-bold tracking-tight text-gray-900">Inspira</div>
        </div>
        
        <div class="flex items-center space-x-2 md:space-x-4">
          <a href="/home" class="px-4 py-2 text-sm font-semibold rounded-full hover:bg-gray-100 transition-colors text-gray-700">Home</a>
          <a href="/feed" class="px-4 py-2 text-sm font-semibold rounded-full hover:bg-gray-100 transition-colors text-gray-700">Feed</a>
          <a href="/profile" class="px-4 py-2 text-sm font-semibold rounded-full bg-gray-900 text-white hover:bg-gray-800 transition-colors">Profile</a>
          <a href="/add" class="w-10 h-10 rounded-full flex items-center justify-center bg-gray-100 hover:bg-gray-200 text-gray-800 transition-colors"><i class="ri-add-line text-xl"></i></a>
          <a href="/logout" class="px-4 py-2 text-sm font-semibold rounded-full text-red-600 hover:bg-red-50 transition-colors">Logout</a>
        </div>
    </nav>

    <!-- Profile Header -->
    <div class="w-full bg-white border-b border-gray-200 pt-12 pb-8">
        <form id="uploadform" hidden action="/uploadfile" method="post" enctype="multipart/form-data">
            <input type="file" name="image" accept="image/*">
        </form>
        
        <div class="max-w-4xl mx-auto flex flex-col items-center">
            <div class="relative group cursor-pointer mb-4" id="upload-trigger">
                <div class="w-32 h-32 md:w-40 md:h-40 bg-gray-200 rounded-full overflow-hidden shadow-md border-4 border-white">
                    <% if(user.profileImage) { %>
                        <img src="/images/uploads/<%=user.profileImage%>" class="w-full h-full object-cover">
                    <% } else { %>
                        <div class="w-full h-full flex items-center justify-center bg-blue-500 text-white text-4xl font-bold">
                            <%= user.username.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                </div>
                <!-- Hover Overlay for Edit -->
                <div class="absolute inset-0 bg-black/40 rounded-full opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center backdrop-blur-sm">
                    <i class="ri-camera-fill text-white text-2xl"></i>
                </div>
                <div class="absolute bottom-1 right-1 w-10 h-10 bg-gray-900 rounded-full flex items-center justify-center text-white border-4 border-white shadow-sm cursor-pointer hover:bg-gray-800 transition-colors z-10" id="uploadicon">
                    <i class="ri-pencil-fill"></i>
                </div>
            </div>
           
            <h1 class="text-3xl font-bold text-gray-900"><%=user.fullname%></h1>
            <h3 class="text-gray-500 font-medium mt-1">@<%=user.username%></h3>
            
            <div class="flex gap-3 mt-6">
                <a href="/edit" class="px-6 py-2.5 bg-gray-200 hover:bg-gray-300 rounded-full text-sm font-semibold text-gray-800 transition-colors">Edit Profile</a>
                <a href="/add" class="px-6 py-2.5 bg-red-600 hover:bg-red-700 text-white rounded-full text-sm font-semibold shadow-md transition-colors">Saved Pins</a>
            </div>
        </div>
    </div>

    <!-- Boards / Folders Section -->
    <main class="w-full max-w-[2000px] mx-auto px-4 sm:px-6 py-8">
        <div class="flex justify-center mb-8">
            <div class="flex space-x-8 border-b border-gray-200">
                <button class="pb-3 border-b-2 border-gray-900 text-gray-900 font-semibold px-2">Saved</button>
                <button class="pb-3 text-gray-500 font-medium hover:text-gray-900 px-2 transition-colors">Created</button>
            </div>
        </div>

        <div class="flex justify-center">
            <!-- Board Card -->
            <a href="/show/posts" class="group block w-full max-w-sm">
                <div class="relative w-full aspect-[4/3] bg-gray-200 rounded-2xl overflow-hidden shadow-sm group-hover:shadow-md transition-shadow">
                    <% if(user.posts && user.posts.length > 0 && user.posts[0].image) { %>
                        <img src="/images/uploads/<%= user.posts[0].image %>" alt="All Pins" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    <% } else { %>
                        <div class="w-full h-full flex flex-col items-center justify-center text-gray-400 bg-gray-100">
                            <i class="ri-image-add-line text-4xl mb-2"></i>
                            <p class="text-sm font-medium">No pins yet</p>
                        </div>
                    <% } %>
                    
                    <!-- Dark Overlay for empty spots in masonry style collection -->
                    <div class="absolute inset-y-0 right-0 w-1/3 border-l-2 border-white bg-gray-100 overflow-hidden hidden sm:block">
                         <% if(user.posts && user.posts.length > 1 && user.posts[1].image) { %>
                            <img src="/images/uploads/<%= user.posts[1].image %>" class="w-full h-1/2 object-cover border-b-2 border-white">
                         <% } else { %>
                            <div class="w-full h-1/2 border-b-2 border-white bg-gray-100"></div>
                         <% } %>
                         <% if(user.posts && user.posts.length > 2 && user.posts[2].image) { %>
                            <img src="/images/uploads/<%= user.posts[2].image %>" class="w-full h-1/2 object-cover">
                         <% } else { %>
                             <div class="w-full h-1/2 bg-gray-200"></div>
                         <% } %>
                    </div>
                </div>
                <div class="mt-3">
                    <h3 class="text-xl font-bold text-gray-900">All Pins</h3>
                    <p class="text-sm text-gray-500 font-medium"><%= user.posts ? user.posts.length : 0 %> pins</p>
                </div>
            </a>
        </div>
    </main>

    <script>
        document.querySelector("#upload-trigger").addEventListener('click', function(){
            document.querySelector("#uploadform input").click();
        });

        document.querySelector("#uploadform input").addEventListener('change', function(){
            if(this.files && this.files.length > 0) {
                document.querySelector("#uploadform").submit();
            }
        });
    </script>
  </body>
</html>