<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link
    href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css"
    rel="stylesheet"
/>
<style>

</style>
  </head>
  <body>
    <nav id="navbar" class="sticky top-0 z-50 flex items-center justify-between px-6 py-4 shadow-sm bg-gray-100">
        <div class="text-lg font-semibold ">Inspira</div>
        <div class="space-x-4">
          <a href="/home" class="text-sm hover:text-blue-500">Home</a>
          <a href="/explore" class="text-sm hover:text-blue-500">Explore</a>
          <a href="/feed" class="text-sm hover:text-blue-500">Feed</a>
          <a href="/logout" class="text-sm hover:text-Red-500  bg-red-700 p-2 rounded">Logout</a>
        </div>
      </nav>
    <div class="profile w-full min-h-screen bg-[url(https://i.pinimg.com/736x/74/5e/40/745e40028d5168d7d832ae72972e80d0.jpg)] text-white pt-1">
        <form  id="uploadform" hidden  action="/uploadfile" method="post" enctype="multipart/form-data">
            <input type="file" name="image">

        </form>
        <div class="profdets flex flex-col items-center mt-10 ">
            <div class="relative">
                <span id="uploadicon" class="w-8 h-8 absolute flex items-center justify-center bottom-0 right-0 rounded-full bg-zinc-700">
                    <i class="ri-pencil-fill"></i>
                </span>

                <div class="w-32 h-32 bg-white rounded-full overflow-hidden">
                    <img src="/images/uploads/<%=user.profileImage%>">
                </div>

            </div>
           
            <h1 class=" mt-2 text-3l font-semibold text-white"><%=user.fullname%></h1>
            <h3 class="text-md ">@<%=user.username%></h3>
            <a href="/edit" class="mt-3 px-5 py-2 bg-zinc-700 rounded-full text-xs ">Edit</a>
            <a href="/add" class="px-10 py-2 bg-red-700 text-xs mt-3  rounded-full">Add Post</a>
        </div>
        <div class="cards flex flex-wrap gap-10 m-5"> 
            <div class="card">
                <div class="w-54 h-40 bg-zinc-100 rounded-lg overflow-hidden">
                    <img src="/images/uploads/<%= user?.posts[0]?.image %>" alt="pin1" class="w-full h-full ">
                </div> 
                <a href="/show/posts" class="inline-block text-l font-semibold mt-3"> Uploaded Pins </a>
                <h5  href="" class="text-sm font-medium opacity-60"><%= user.posts.length%> pins</h5>
            </div>
        </div>
    </div>

    <script>
        document.querySelector("#uploadicon").addEventListener('click',function(){
            document.querySelector("#uploadform input").click();
        })

        document.querySelector("#uploadform input").addEventListener('change',function(){
            document.querySelector("#uploadform").submit();
        })
    </script>
  </body>
</html>