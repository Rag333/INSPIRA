<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link
    href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css"
    rel="stylesheet"
/>
<style>

</style>
  </head>
  <body>
    <nav id="navbar" class="sticky top-0 z-50 flex items-center justify-between px-6 py-4 shadow-sm bg-gray-100">
        <div class="text-lg font-semibold ">Inspira</div>
        <div class="space-x-4">
          <a href="/home" class="text-sm hover:text-blue-500">Home</a>
          <a href="/explore" class="text-sm hover:text-blue-500">Explore</a>
          <a href="/feed" class="text-sm hover:text-blue-500">Feed</a>
          <a href="/logout" class="text-sm hover:text-Red-500  bg-red-700 p-2 rounded">Logout</a>
        </div>
      </nav>

      <div class="w-full min-h-screen bg-zinc-800 px-10 py-5 text-white">
        <h1 class="text-xl font-semibold mt-2"> Create a new post.</h1>
        <hr class="opacity-30 mt-2">
        <form action="/createpost" class="mt-5  flex flex-col items-center " method="post" enctype="multipart/form-data">
            <input class=" block w-1/3 px-3 py-2 border-2 rounded" type="file" name="postImage">
            <input class="text-white block w-1/3 px-3 py-2 border-2 rounded" type="text" placeholder="Title" name="title">
            <textarea class="text-white block w-1/3 px-3 py-2 border-2 rounded" type="text" placeholder="Description" name="description"></textarea>
            <input class="block w-1/3 px-3 py-2 border-2 rounded bg-red-700" type="submit" value="Create post">

        </form>
      </div>
  </body>
</html>