<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link
    href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css"
    rel="stylesheet"
/>
<style>

</style>
  </head>
  <body>
    <nav id="navbar" class="sticky top-0 z-50 flex items-center justify-between px-6 py-4 shadow-sm bg-gray-100">
        <div class="text-lg font-semibold ">Inspira</div>
        <div class="space-x-4">
          <a href="/home" class="text-sm hover:text-blue-500">Home</a>
          <a href="/explore" class="text-sm hover:text-blue-500">Explore</a>
          <a href="/feed" class="text-sm hover:text-blue-500">Feed</a>
          <a href="/logout" class="text-sm hover:text-Red-500  bg-red-700 p-2 rounded">Logout</a>
        </div>
      </nav>

      <div class="w-full min-h-screen bg-zinc-900 px-10 py-10 text-white">
        <h1 class="text-3xl font-bold mt-2 mb-6">Create a new Pin</h1>
        
        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Left: Options & Preview -->
            <div class="flex-1 bg-zinc-800 p-6 rounded-2xl shadow-xl flex flex-col items-center justify-center min-h-[400px] border border-zinc-700 relative overflow-hidden group transition-all">
                <div id="image-preview-container" class="hidden w-full h-full absolute inset-0 bg-zinc-800 z-10 flex flex-col items-center justify-center">
                   <img id="image-preview" class="w-full h-full object-cover" />
                   <button id="clear-image-btn" class="absolute top-4 right-4 bg-black/50 hover:bg-black/80 text-white p-2 rounded-full cursor-pointer transition-colors backdrop-blur-md">
                        <i class="ri-close-line text-xl"></i>
                   </button>
                   <div id="loading-overlay" class="hidden absolute inset-0 bg-black/60 flex flex-col items-center justify-center backdrop-blur-sm z-20">
                        <i class="ri-loader-4-line text-4xl animate-spin text-white mb-2"></i>
                        <p class="text-sm font-medium">Generating your masterpiece...</p>
                   </div>
                </div>

                <div id="upload-options" class="flex flex-col items-center gap-6 w-full max-w-sm z-0">
                    <div class="text-center">
                        <i class="ri-upload-cloud-2-line text-5xl text-zinc-400 mb-2 block"></i>
                        <p class="text-zinc-400 font-medium">Choose from your files</p>
                    </div>
                    
                    <button type="button" onclick="document.getElementById('file-upload').click()" class="bg-zinc-700 hover:bg-zinc-600 text-white font-semibold py-3 px-6 rounded-full w-full transition-colors">
                        Upload Image
                    </button>
                    
                    <div class="flex items-center w-full gap-3 opacity-50">
                        <hr class="flex-1 border-zinc-600"><span class="text-xs">OR</span><hr class="flex-1 border-zinc-600">
                    </div>

                    <div class="w-full flex gap-2">
                        <input id="ai-prompt-input" type="text" placeholder="Generate with AI (e.g. A cyberpunk city)" class="flex-1 bg-zinc-700 text-white px-4 py-3 rounded-xl border border-zinc-600 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all text-sm">
                        <button type="button" id="generate-ai-btn" class="bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 hover:opacity-90 text-white font-semibold py-3 px-5 rounded-xl transition-all shadow-lg flex items-center justify-center">
                            <i class="ri-magic-line"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Right: Form Details -->
            <div class="flex-1 lg:max-w-md">
                <form id="post-form" action="/createpost" class="flex flex-col gap-5" method="post" enctype="multipart/form-data">
                    <input id="file-upload" class="hidden" type="file" name="postImage" accept="image/*">
                    <input id="ai-image-url" type="hidden" name="aiImageUrl" value="">

                    <div>
                        <label class="block text-sm font-medium text-zinc-400 mb-1 ml-1">Title</label>
                        <input required class="w-full bg-zinc-800 text-white px-4 py-3 rounded-xl border border-zinc-700 focus:outline-none focus:border-blue-500 transition-all text-lg font-medium placeholder-zinc-500" type="text" placeholder="Add a title" name="title">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-zinc-400 mb-1 ml-1">Description</label>
                        <textarea class="w-full bg-zinc-800 text-white px-4 py-3 rounded-xl border border-zinc-700 focus:outline-none focus:border-blue-500 transition-all min-h-[150px] resize-none placeholder-zinc-500" placeholder="Tell everyone what your Pin is about" name="description"></textarea>
                    </div>
                    
                    <button type="submit" id="submit-post-btn" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-4 rounded-full w-full transition-transform active:scale-95 shadow-lg mt-4 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer">
                        Save Pin
                    </button>
                </form>
            </div>
        </div>
      </div>

      <script>
        const fileUpload = document.getElementById('file-upload');
        const aiPromptInput = document.getElementById('ai-prompt-input');
        const generateAiBtn = document.getElementById('generate-ai-btn');
        const imagePreviewContainer = document.getElementById('image-preview-container');
        const imagePreview = document.getElementById('image-preview');
        const clearImageBtn = document.getElementById('clear-image-btn');
        const aiImageUrlInput = document.getElementById('ai-image-url');
        const loadingOverlay = document.getElementById('loading-overlay');
        const postForm = document.getElementById('post-form');

        // Handle File Upload Preview
        fileUpload.addEventListener('change', function(e) {
            if (e.target.files && e.target.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    imagePreview.src = e.target.result;
                    imagePreviewContainer.classList.remove('hidden');
                    aiImageUrlInput.value = ''; // Reset AI URL if file selected
                }
                reader.readAsDataURL(e.target.files[0]);
            }
        });

        // Handle AI Generation
        generateAiBtn.addEventListener('click', () => {
            const prompt = aiPromptInput.value.trim();
            if (!prompt) return alert('Please enter a prompt for the AI');

            const safePrompt = encodeURIComponent(prompt);
            const seed = Math.floor(Math.random() * 1000000);
            const pollinationsUrl = `https://image.pollinations.ai/prompt/${safePrompt}?nologo=true&seed=${seed}&width=800&height=1200`;

            // Reset current file if any
            fileUpload.value = '';
            
            imagePreviewContainer.classList.remove('hidden');
            loadingOverlay.classList.remove('hidden');

            const img = new Image();
            img.onload = () => {
                imagePreview.src = pollinationsUrl;
                aiImageUrlInput.value = pollinationsUrl;
                loadingOverlay.classList.add('hidden');
            };
            img.onerror = () => {
                loadingOverlay.classList.add('hidden');
                imagePreviewContainer.classList.add('hidden');
                alert('Failed to generate image. Please try again.');
            };
            img.src = pollinationsUrl;
        });

        // Clear Image
        clearImageBtn.addEventListener('click', () => {
            imagePreviewContainer.classList.add('hidden');
            imagePreview.src = '';
            fileUpload.value = '';
            aiImageUrlInput.value = '';
        });

        // Handle Form Submission
        postForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const isFile = fileUpload.files && fileUpload.files.length > 0;
            const isAi = aiImageUrlInput.value !== '';

            if (!isFile && !isAi) {
                return alert('Please upload an image or generate one using AI.');
            }

            const title = document.querySelector('input[name="title"]').value;
            const description = document.querySelector('textarea[name="description"]').value;

            if (isAi) {
                // Submit to AI route via fetch since we need to download it on backend
                const submitBtn = document.getElementById('submit-post-btn');
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="ri-loader-4-line animate-spin inline-block mr-2"></i> Saving...';

                try {
                    const response = await fetch('/createpost/ai', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            title: title,
                            description: description,
                            imageUrl: aiImageUrlInput.value
                        })
                    });

                    const data = await response.json();
                    if (data.success) {
                        window.location.href = '/profile';
                    } else {
                        throw new Error(data.error);
                    }
                } catch (error) {
                    alert('Error saving AI post: ' + error.message);
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Save Pin';
                }
            } else {
                // Normal file upload form submission
                postForm.submit();
            }
        });
      </script>
  </body>
</html>