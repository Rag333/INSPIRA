<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Register - Inspira</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="./stylesheets/register.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
  <style>
    body {
      font-size: 0.9rem;
    }
    .form-control, .btn {
      padding: 0.4rem 0.75rem;
      font-size: 0.9rem;
    }
    h2 {
      font-size: 1.5rem;
    }
    .container-fluid {
      padding: 1rem;
    }
    .form-label {
      margin-bottom: 0.2rem;
    }
    .social-btns .btn {
      padding: 0.3rem 0.5rem;
    }
    #image img {
      max-height: 300px;
      width: auto;
    }
  </style>
</head>
<body>
  <div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center bg-dark">
    <div class="row shadow rounded-4 overflow-hidden w-100" style="max-width: 900px;">
      
      
      <!-- Form Side -->
      <div class="col-md-6 p-4 bg-white ">
        <div class="arrow">
      <a href="/home"> <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#000000"><path d="M240-200h120v-240h240v240h120v-360L480-740 240-560v360Zm-80 80v-480l320-240 320 240v480H520v-240h-80v240H160Zm320-350Z"/></svg></a>   
        </div>
        <h2 class="fw-bold mb-1">Create Account</h2>
        <p class="text-muted mb-3">Sign up with <strong>Inspira</strong></p>

        <form action="/register" method="post">
          <div class="mb-2">
            <label for="fullname" class="form-label">Fullname</label>
            <input type="text" name="fullname" class="form-control rounded-pill" id="fullname" placeholder="User" />
          </div>
          <div class="mb-2">
            <label for="nameInput" class="form-label">Username</label>
            <input type="text" name="username" class="form-control rounded-pill" id="nameInput" placeholder="User123" />
          </div>
          <div class="mb-2">
            <label for="emailInput" class="form-label">Email</label>
            <input type="email" name="email" class="form-control rounded-pill" id="emailInput" placeholder="you@example.com" />
          </div>
          <div class="mb-2">
            <label for="passwordInput" class="form-label">Password</label>
            <input type="password" name="password" class="form-control rounded-pill" id="passwordInput" placeholder="••••••••" />
          </div>
          <button type="submit" class="btn btn-dark w-100 rounded-pill mt-2" href="/login">Sign up</button>

          <div class="text-center my-2 text-muted">or continue with</div>

          <div class="d-flex gap-2 social-btns">
            <button type="button" class="btn btn-outline-dark w-50 rounded-pill">
              <i class="bi bi-google"></i>
            </button>
            <button type="button" class="btn btn-outline-dark w-50 rounded-pill">
              <i class="bi bi-facebook"></i>
            </button>
          </div>
        </form>

        <p class="mt-3 text-center text-muted">
          Already have an account? <a href="/login" class="text-primary text-decoration-none">Log in</a>
        </p>
      </div>

      <!-- Illustration Side -->
      <div class="col-md-6 d-none d-md-flex align-items-center justify-content-center bg-white " id="image">
        <img src="https://images.unsplash.com/vector-1741717181040-e90a5a8c968f?q=80&w=3272&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
        alt="Illustration"
        class="img-fluid rounded-4"
         style="max-height: 470px; width: auto;" />
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>