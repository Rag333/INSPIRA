<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sign Up - Inspira</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet" />
</head>
<body class="bg-gray-50 min-h-screen font-sans flex items-center justify-center p-4">
  
  <div class="absolute top-6 left-6 flex items-center gap-2 cursor-pointer hover:opacity-80 transition-opacity" onclick="window.location.href='/home'">
      <div class="w-8 h-8 rounded-full bg-red-600 flex items-center justify-center text-white font-bold italic">I</div>
      <div class="text-xl font-bold tracking-tight text-gray-900">Inspira</div>
  </div>

  <div class="w-full max-w-4xl bg-white rounded-3xl shadow-xl overflow-hidden flex flex-col md:flex-row-reverse">
    
    <!-- Illustration Side -->
    <div class="hidden md:flex w-1/2 bg-gray-100 p-8 items-center justify-center relative overflow-hidden group">
      <img src="https://images.unsplash.com/photo-1745676353163-539761e42831?q=80&w=2787&auto=format&fit=crop" alt="Inspiration" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
      <div class="relative z-10 text-white text-center mt-auto mb-10 px-4">
          <h2 class="text-3xl font-bold mb-2">Join Inspira</h2>
          <p class="text-gray-200 text-sm">Find what you love and save it for later.</p>
      </div>
    </div>

    <!-- Form Side -->
    <div class="w-full md:w-1/2 p-8 md:p-12 flex flex-col justify-center">
      <div class="w-12 h-12 rounded-full bg-red-600 flex items-center justify-center text-white font-bold italic mx-auto mb-6 text-2xl shadow-md">I</div>
      
      <h2 class="text-2xl font-bold text-center text-gray-900 mb-2">Welcome to Inspira</h2>
      <p class="text-center text-gray-500 mb-8 text-sm">Find new ideas to try</p>

      <form action="/register" method="post" class="flex flex-col gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1 ml-1 cursor-pointer">Full Name</label>
          <input type="text" name="fullname" class="w-full bg-white border-2 border-gray-200 px-4 py-3 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all text-sm font-medium placeholder-gray-400" placeholder="e.g. Jane Doe" required />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1 ml-1 cursor-pointer">Username</label>
          <input type="text" name="username" class="w-full bg-white border-2 border-gray-200 px-4 py-3 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all text-sm font-medium placeholder-gray-400" placeholder="Choose a username" required />
        </div> 

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1 ml-1 cursor-pointer">Email</label>
          <input type="email" name="email" class="w-full bg-white border-2 border-gray-200 px-4 py-3 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all text-sm font-medium placeholder-gray-400" placeholder="you@example.com" required />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1 ml-1 cursor-pointer">Password</label>
          <input type="password" name="password" class="w-full bg-white border-2 border-gray-200 px-4 py-3 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all text-sm font-medium placeholder-gray-400" placeholder="Create a password" required />
        </div>

        <button type="submit" class="w-full bg-red-600 text-white font-bold py-3 px-4 rounded-full hover:bg-red-700 transition-colors shadow-md mt-4">Continue</button>
      </form>

      <div class="mt-8 relative flex items-center justify-center">
        <hr class="w-full border-gray-200">
        <span class="absolute bg-white px-4 text-sm text-gray-500 font-medium">OR</span>
      </div>

      <div class="flex flex-col gap-3 mt-8">
        <button type="button" class="w-full flex items-center justify-center gap-3 bg-white border-2 border-gray-200 text-gray-700 font-semibold py-3 px-4 rounded-full hover:bg-gray-50 transition-colors">
          <i class="ri-google-fill text-xl text-red-500"></i> Google
        </button>
      </div>

      <p class="mt-6 text-center text-xs text-gray-500 leading-relaxed px-4">
        By continuing, you agree to Inspira's <a href="#" class="font-bold text-gray-700">Terms of Service</a> and acknowledge you've read our <a href="#" class="font-bold text-gray-700">Privacy Policy</a>
      </p>

      <div class="mt-6 pt-6 border-t border-gray-100 text-center">
        <p class="text-sm text-gray-600">
            Already a member? <a href="/login" class="text-gray-900 font-bold hover:underline">Log in</a>
        </p>
      </div>
    </div>

  </div>

</body>
</html>