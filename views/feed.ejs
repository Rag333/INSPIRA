<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet" />
    <style>
      /* Smooth image loading */
      img { transition: opacity 0.3s ease-in-out; }
      img[loading] { opacity: 0; }
      img.loaded { opacity: 1; }
      
      /* Hide scrollbar for a cleaner look */
      ::-webkit-scrollbar { width: 8px; }
      ::-webkit-scrollbar-track { background: #f1f1f1; }
      ::-webkit-scrollbar-thumb { background: #888; border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: #555; }
    </style>
  </head>
  <body class="bg-gray-50 min-h-screen font-sans">
    
    <!-- Glassmorphism Navbar -->
    <nav id="navbar" class="sticky top-0 z-50 flex items-center justify-between px-6 py-4 backdrop-blur-md bg-white/80 shadow-sm border-b border-gray-200/50 transition-all duration-300">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-red-600 flex items-center justify-center text-white font-bold italic">I</div>
            <div class="text-xl font-bold tracking-tight text-gray-900">Inspira</div>
        </div>
        
        <div class="hidden md:flex flex-1 max-w-2xl px-8">
            <div class="w-full relative group">
                <i class="ri-search-line absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500 transition-colors"></i>
                <input type="text" placeholder="Search for ideas" class="w-full bg-gray-100 hover:bg-gray-200 focus:bg-white text-gray-900 px-12 py-3 rounded-full outline-none focus:ring-2 focus:ring-blue-500/50 transition-all text-sm font-medium">
            </div>
        </div>

        <div class="flex items-center space-x-2 md:space-x-4">
          <a href="/home" class="px-4 py-2 text-sm font-semibold rounded-full hover:bg-gray-100 transition-colors text-gray-700">Home</a>
          <a href="/feed" class="px-4 py-2 text-sm font-semibold rounded-full bg-gray-900 text-white hover:bg-gray-800 transition-colors">Feed</a>
          <a href="/profile" class="px-4 py-2 text-sm font-semibold rounded-full hover:bg-gray-100 transition-colors text-gray-700">Profile</a>
          <a href="/add" class="w-10 h-10 rounded-full flex items-center justify-center bg-gray-100 hover:bg-gray-200 text-gray-800 transition-colors"><i class="ri-add-line text-xl"></i></a>
          <a href="/logout" class="px-4 py-2 text-sm font-semibold rounded-full text-red-600 hover:bg-red-50 transition-colors">Logout</a>
        </div>
    </nav>

    <!-- Main Content Grid -->
    <main class="w-full max-w-[2000px] mx-auto px-4 sm:px-6 py-8">
        <% if (posts.length === 0) { %>
            <div class="flex flex-col items-center justify-center mt-20 text-gray-500">
                <i class="ri-image-line text-6xl mb-4 opacity-50"></i>
                <h2 class="text-xl font-semibold">No pins found</h2>
                <p class="text-sm mt-2">Be the first to create one!</p>
                <a href="/add" class="mt-6 px-6 py-3 bg-red-600 text-white rounded-full font-semibold hover:bg-red-700 transition-colors shadow-md">Create Pin</a>
            </div>
        <% } else { %>
            <div class="columns-2 sm:columns-3 md:columns-4 lg:columns-5 xl:columns-6 gap-4 space-y-4">
                <% posts.forEach(function(elem){ %>
                    <!-- Pin Card -->
                    <div class="break-inside-avoid relative group rounded-2xl overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-300">
                        <!-- Image -->
                        <img src="/images/uploads/<%= elem.image %>" class="w-full object-cover rounded-2xl group-hover:brightness-75 transition-all duration-300" onload="this.classList.add('loaded')" loading="lazy" alt="<%= elem.title %>">
                        
                        <!-- Hover Overlay -->
                        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-between p-4 bg-black/20">
                            <div class="flex justify-end">
                                <button class="bg-red-600 hover:bg-red-700 text-white text-sm font-bold py-2 px-4 rounded-full shadow-lg transition-transform active:scale-95">Save</button>
                            </div>
                            
                            <div class="flex items-center justify-between mt-auto backdrop-blur-md bg-white/20 p-2 rounded-xl">
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded-full bg-gray-200 overflow-hidden flex-shrink-0 border border-white/50">
                                        <% if(elem.user.profileImage) { %>
                                            <img src="/images/uploads/<%= elem.user.profileImage %>" class="w-full h-full object-cover">
                                        <% } else { %>
                                            <div class="w-full h-full bg-blue-500 flex items-center justify-center text-white text-xs font-bold"><%= elem.user.username.charAt(0).toUpperCase() %></div>
                                        <% } %>
                                    </div>
                                    <p class="text-xs font-medium text-white shadow-sm truncate max-w-[100px]"><%= elem.user.username %></p>
                                </div>
                                <div class="flex gap-2">
                                    <button class="w-8 h-8 rounded-full bg-white/80 hover:bg-white flex items-center justify-center text-gray-800 backdrop-blur-sm transition-colors"><i class="ri-share-forward-line"></i></button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Details below image -->
                    <div class="mt-2 mb-6 px-1">
                        <h5 class="text-sm font-semibold text-gray-900 truncate leading-tight"><%= elem.title %></h5>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </main>
  </body>
</html>