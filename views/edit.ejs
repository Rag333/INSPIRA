<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Edit Profile - INSPIRA</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet" />
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #f0f2f5;
    }

    .edit-profile-card {
      max-width: 520px;
      margin: auto;
      background: #fff;
      padding: 2rem;
      border-radius: 1.5rem;
      box-shadow: 0 0 20px rgba(0,0,0,0.05);
    }
   
    

    .avatar-preview {
      width: 120px;
      height: 120px;
      object-fit: cover;
      display: block;
      border-radius: 50%;
      margin: auto;
      border: 3px solid #000;
    }

    .form-control {
      border-radius: 2rem;
    }

    .btn-dark {
      border-radius: 2rem;
    }
  </style>
</head>
<body>

<div class="container py-5">
    <a href="/profile"><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#000000"><path d="m313-440 224 224-57 56-320-320 320-320 57 56-224 224h487v80H313Z"/></svg></a>
  <div class="edit-profile-card text-center">
    <h3 class="mb-4 fw-bold">Edit Your Profile</h3>

    <!-- Profile Image Preview -->
     <div id="profile" class="d-flex justify-content-center align-items-center">
        <img src="https://img.freepik.com/premium-photo/round-user-icon-isolated-white-background-black-white-3d-rendering_63135-3893.jpg?ga=GA1.1.2023936264.1732558294&semt=ais_hybrid&w=740" id="avatarPreview"  class="avatar-preview mb-3 " alt=" Photo">
     </div>
   

    <!-- Edit Form -->
    <form action="/update-profile" method="POST" enctype="multipart/form-data">
      <div class="mb-3 text-start">
        <label for="avatarInput" class="form-label ">Profile Photo</label>
        <input class="form-control" type="file" name="avatar" id="avatarInput" accept="image/*" onchange="previewImage(event)">
      </div>

      <div class="mb-3 text-start">
        <label for="fullname" class="form-label">Full Name</label>
        <input type="text" name="fullname" id="fullname" class="form-control" placeholder="Raze">
      </div>

      <div class="mb-4 text-start">
        <label for="username" class="form-label">Username</label>
        <input type="text" name="username" id="username" class="form-control" placeholder="raze_inspira">
      </div>

      <button type="submit" class="btn btn-dark w-100">Save Changes</button>
    </form>
  </div>
</div>

<script>
  function previewImage(event) {
    const avatarPreview = document.getElementById('avatarPreview');
    avatarPreview.src = URL.createObjectURL(event.target.files[0]);
  }
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>